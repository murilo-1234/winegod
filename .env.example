# WineGod — Environment Variables

# PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/winegod

# Claude API (IA fallback para lojas desconhecidas)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini (enrichment)
GOOGLE_API_KEY=AIza...

# Grok (enrichment)
XAI_API_KEY=xai-...

# DeepSeek (enrichment)
DEEPSEEK_API_KEY=sk-...

# IPRoyal Proxy (para Mercado Livre / Amazon)
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_USER=
PROXY_PASS=

# OpenAI (opcional, enrichment alternativo)
OPENAI_API_KEY=sk-proj-...
